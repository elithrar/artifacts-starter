{
  "name": "artifacts-starter",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-15",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "artifacts": [
    {
      "binding": "ARTIFACTS",
      "namespace": "default",
    },
  ],
  "ratelimits": [
    {
      "name": "CREATE_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 25,
        "period": 10,
      },
    },
  ],
}
